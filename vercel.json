{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "devCommand": null,
  "rewrites": [
    {
      "source": "/masinfo.html",
      "destination": "/masinfo.html"
    },
    {
      "source": "/masinfo",
